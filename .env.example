# =============================================================================
# ExpressVPN Docker Gateway — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains your activation code.
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────
# Get your activation code from: https://www.expressvpn.com/setup#manual
ACTIVATION_CODE=your_expressvpn_activation_code_here

# Note: Place your expressvpn.run installer in /docker/app-stack/expressvpn/

# ── VPN Server ────────────────────────────────────────────────────────────────
# Options: smart | <country name> | <city alias>
# Examples: "USA - New York", "USA - New Jersey", "smart"
# Run `expressvpn list all` inside the container to see all options.
SERVER=smart

# ── Protocol (Lightway = fastest) ────────────────────────────────────────────
# lightway_udp  — Fastest. Best for stable connections. RECOMMENDED.
# lightway_tcp  — Better on restrictive networks (firewalls, hotel WiFi).
# auto          — ExpressVPN picks the best protocol automatically.
PREFERRED_PROTOCOL=lightway_udp

# ── Lightway Cipher ───────────────────────────────────────────────────────────
# auto      — ExpressVPN picks AES or ChaCha20 based on your CPU. RECOMMENDED.
# aes256    — Hardware-accelerated AES (best on modern Intel/AMD with AES-NI).
# chacha20  — Software cipher (best on ARM or CPUs without AES-NI).
LIGHTWAY_CIPHER=auto

# ── Firewall / Kill Switch ────────────────────────────────────────────────────
# Comma-separated CIDR subnets allowed to bypass the kill switch.
# These are your LAN ranges (e.g. for Sonarr to reach your NAS).
FIREWALL_OUTBOUND_SUBNETS=192.168.90.0/24

# ── Watchdog ──────────────────────────────────────────────────────────────────
# Seconds between VPN status checks. Reduces reconnect time if VPN drops.
RECONNECT_DELAY=30

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=America/New_York
